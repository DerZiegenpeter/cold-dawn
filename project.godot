; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Cold Dawn"
run/main_scene="uid://dh8kpne5vj6mw"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

CameraSystem="*res://scripts/CameraSystem.gd"
InputSystem="*res://scripts/InputSystem.gd"
CommandSystem="*res://scripts/CommandSystem.gd"
PathfindingSystem="*res://scripts/PathfindingSystem.gd"
MovementSystem="*res://scripts/MovementSystem.gd"
UnitManager="*res://scripts/UnitManager.gd"
LandSystem="*res://scripts/LandSystem.gd"
CollisionSystem="*res://scripts/CollisionSystem.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
